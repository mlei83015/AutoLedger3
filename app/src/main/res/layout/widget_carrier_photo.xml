<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/widget_bg">

    <FrameLayout
        android:id="@+id/widget_photo_wrap"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:background="@drawable/widget_photo_bg"
        android:padding="3dp">
        <ImageView
            android:id="@+id/widget_photo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@drawable/widget_photo_placeholder" />
        <TextView
            android:id="@+id/widget_photo_hint"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="點此設定圖片"
            android:textColor="#4E6C7A"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

    <ImageView
        android:id="@+id/widget_carrier_barcode"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="6dp"
        android:padding="4dp"
        android:background="@drawable/widget_barcode_bg"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">
        <TextView
            android:id="@+id/widget_balance"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="$0"
            android:textColor="#063B52"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:singleLine="true" />
        <TextView
            android:id="@+id/widget_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="今日 $0"
            android:textColor="#557687"
            android:textSize="11sp"
            android:maxLines="1"
            android:singleLine="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="7dp">
        <TextView
            android:id="@+id/widget_expense"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="＋支出"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            android:maxLines="1"
            android:singleLine="true"
            android:background="@drawable/widget_button_expense" />
        <TextView
            android:id="@+id/widget_income"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="＋收入"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            android:maxLines="1"
            android:singleLine="true"
            android:background="@drawable/widget_button_income" />
    </LinearLayout>
</LinearLayout>
